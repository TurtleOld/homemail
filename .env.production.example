# Production Environment Configuration for example.com

# ==========================================
# OAuth 2.1 Configuration
# ==========================================

# OAuth Client ID (must match Stalwart configuration)
OAUTH_CLIENT_ID=mailclient

# Stalwart OAuth Authorization Endpoint (public URL)
OAUTH_AUTHORIZATION_ENDPOINT=https://example.com/oauth/authorize

# Stalwart OAuth Token Endpoint (public URL)
OAUTH_TOKEN_ENDPOINT=https://example.com/oauth/token

# OAuth Redirect URI (where user returns after authorization)
# MUST be registered in Stalwart OAuth client configuration
OAUTH_REDIRECT_URI=https://example.com/oauth/callback

# ==========================================
# Stalwart Mail Server Configuration
# ==========================================

# Public Stalwart URL (for OAuth discovery)
STALWART_PUBLIC_URL=https://example.com

# Internal Stalwart URL (for server-side requests, if different)
# Use this if your Next.js app can reach Stalwart via internal network
# STALWART_BASE_URL=http://stalwart:8080

# JMAP API URL
JMAP_API_URL=https://example.com/jmap

# ==========================================
# Application Configuration
# ==========================================

# Public URL of this application
NEXT_PUBLIC_APP_URL=https://example.com


# Node environment
NODE_ENV=production

# ==========================================
# HomeMail redesign foundations
# ==========================================

# Keep every new capability inert until its later phase exit gate is met.
HOMEMAIL_FEATURE_LIST_FIRST_MAIL=false
HOMEMAIL_FEATURE_PROTECTED_MESSAGE_CONTENT=false
HOMEMAIL_FEATURE_REMOTE_IMAGE_FETCHING=false

# Stalwart API-key credential dedicated to HomeMail's own read-only Stalwart
# queue/report monitoring (see docs/adr/0009, docs/adr/0010). Create it in
# Stalwart Web Admin under Account > Credentials > API Keys, scoped to only
# queue/report read operations — never /api/settings/* access. Required for
# the System status page in Settings; that page shows an error state if unset.
STALWART_ADMIN_API_KEY=

# Optional dedicated secret for signed image resources. When omitted, HomeMail
# derives a separate signing key from SESSION_SECRET.
HOMEMAIL_IMAGE_SIGNING_SECRET=

# Per-account-and-client-IP image resource requests per minute.
RATE_LIMIT_IMAGE_RESOURCE_MAX=120
RATE_LIMIT_IMAGE_RESOURCE_WINDOW=60000

# ==========================================
# Security Configuration
# ==========================================

# Session Secret (REQUIRED - generate with: openssl rand -base64 32)
SESSION_SECRET=REPLACE_WITH_YOUR_GENERATED_SECRET_MIN_32_CHARS

# Allowed origin hosts (comma-separated, if needed)
ALLOWED_ORIGIN_HOSTS=example.com

STALWART_BASE_URL=http://stalwart:8080
STALWART_SMTP_HOST=stalwart
STALWART_SMTP_PORT=587
STALWART_SMTP_SECURE=false
STALWART_AUTH_MODE=oauth

# ==========================================
# ntfy Push Notifications
# ==========================================

NTFY_URL=https://ntfy.example.com
NTFY_TOKEN=your-ntfy-access-token
NTFY_TOPIC_PATTERN=homemail-user-{accountId}

# Allow validating mobile poll tokens against the JMAP session when OAuth
# introspection cannot confirm account ownership (required for Stalwart).
MOBILE_NTFY_ALLOW_JMAP_TOKEN_VALIDATION=true

# Firebase service account JSON minified into a single line.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id"}
